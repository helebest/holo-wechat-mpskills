{
  "name": "pier",
  "version": "1.0.0",
  "description": "Pier 主题 - 灵感源自 Pie 排版美学，青绿配深蓝，兼具科技感与人文温度",

  "colors": {
    "primary": "#26a69a",
    "primary_dark": "#1a535c",
    "primary_light": "#4ecdc4",
    "primary_pale": "#e0f2f1",

    "accent": "#0d2137",
    "accent_light": "#1e3a5f",

    "text": "#0d2137",
    "text_secondary": "#3d5a73",
    "text_tertiary": "#6b8299",
    "text_muted": "#94a3b8",

    "bg_warm": "#faf8f5",
    "bg_cool": "#f0f7f6",
    "bg_code": "#f8fafa",
    "bg_quote": "#f5faf9",

    "border": "#d1e0dd",
    "border_light": "#e8f0ee",
    "border_accent": "#b2dfdb",

    "success": "#10b981",
    "warning": "#f59e0b",
    "error": "#ef4444",
    "info": "#3b82f6"
  },

  "fonts": {
    "body": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif",
    "heading": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'PingFang SC', 'Microsoft YaHei', sans-serif",
    "code": "'JetBrains Mono', 'Fira Code', 'SF Mono', Consolas, 'Liberation Mono', Menlo, monospace"
  },

  "tokens": {
    "radius_xs": "3px",
    "radius_sm": "4px",
    "radius_md": "6px",
    "radius_lg": "8px",
    "radius_xl": "12px",

    "shadow_sm": "0 1px 3px rgba(13, 33, 55, 0.04)",
    "shadow_md": "0 4px 12px rgba(13, 33, 55, 0.06)",
    "shadow_lg": "0 8px 24px rgba(13, 33, 55, 0.08)"
  },

  "elements": {
    "section": {
      "font-family": "{fonts.body}",
      "font-size": "16px",
      "line-height": "1.8",
      "color": "{colors.text}",
      "letter-spacing": "0.03em",
      "word-spacing": "0.05em"
    },

    "h1": {
      "text-align": "center",
      "font-family": "{fonts.heading}",
      "font-size": "20px",
      "font-weight": "700",
      "color": "{colors.accent}",
      "margin": "40px 0 32px 0",
      "padding": "0 0 20px 0",
      "letter-spacing": "0.05em",
      "border-bottom": "3px solid {colors.primary}"
    },

    "h2": {
      "font-family": "{fonts.heading}",
      "font-size": "18px",
      "font-weight": "600",
      "color": "{colors.accent}",
      "margin": "36px 0 20px 0",
      "padding-left": "12px",
      "border-left": "4px solid {colors.primary}",
      "letter-spacing": "0.02em"
    },

    "h3": {
      "font-family": "{fonts.heading}",
      "font-size": "16px",
      "font-weight": "600",
      "color": "{colors.accent}",
      "margin": "28px 0 16px 0",
      "padding-left": "0",
      "letter-spacing": "0.02em"
    },

    "h4": {
      "font-family": "{fonts.heading}",
      "font-size": "16px",
      "font-weight": "600",
      "color": "{colors.text}",
      "margin": "24px 0 12px 0"
    },

    "p": {
      "margin": "20px 0",
      "text-align": "justify",
      "line-height": "1.9",
      "font-size": "16px"
    },

    "strong": {
      "display": "inline",
      "font-weight": "600",
      "color": "{colors.accent}"
    },

    "em": {
      "font-style": "italic",
      "color": "{colors.text_secondary}"
    },

    "a": {
      "color": "{colors.primary}",
      "text-decoration": "none",
      "border-bottom": "1px solid {colors.border_accent}"
    },

    "blockquote": {
      "margin": "28px 0",
      "padding": "20px 24px 20px 20px",
      "border-left": "4px solid {colors.primary}",
      "background": "{colors.bg_quote}",
      "border-radius": "0 {tokens.radius_lg} {tokens.radius_lg} 0",
      "color": "{colors.text_secondary}",
      "font-size": "16px",
      "font-style": "normal"
    },

    "blockquote_p": {
      "margin": "12px 0",
      "text-indent": "0",
      "line-height": "1.8"
    },

    "ul": {
      "margin": "20px 0",
      "padding-left": "30px"
    },

    "ol": {
      "margin": "20px 0",
      "padding-left": "30px"
    },

    "li": {
      "margin": "12px 0",
      "line-height": "1.8",
      "font-size": "16px"
    },

    "li_bullet": {
      "display": "inline",
      "color": "{colors.primary}",
      "margin-right": "8px"
    },

    "ol_li": {
      "margin": "12px 0",
      "line-height": "1.8",
      "font-size": "16px"
    },

    "ol_number": {
      "display": "inline",
      "color": "{colors.primary_dark}",
      "font-weight": "600",
      "margin-right": "8px"
    },

    "code": {
      "font-family": "{fonts.code}",
      "font-size": "14px",
      "color": "{colors.primary_dark}",
      "background": "{colors.primary_pale}",
      "padding": "2px 6px",
      "border-radius": "{tokens.radius_sm}",
      "border": "1px solid {colors.border_accent}"
    },

    "pre": {
      "background": "{colors.bg_code}",
      "padding": "16px 20px",
      "border-radius": "{tokens.radius_lg}",
      "overflow-x": "auto",
      "margin": "24px 0",
      "border": "1px solid {colors.border_light}"
    },

    "pre_code": {
      "font-family": "{fonts.code}",
      "font-size": "13px",
      "line-height": "1.8",
      "color": "{colors.text}",
      "background": "transparent",
      "padding": "0",
      "border": "none"
    },

    "code_line_number": {
      "display": "inline-block",
      "width": "30px",
      "color": "{colors.text_muted}",
      "text-align": "right",
      "margin-right": "12px",
      "user-select": "none"
    },

    "img": {
      "max-width": "100%",
      "height": "auto",
      "display": "block",
      "margin": "28px auto",
      "border-radius": "{tokens.radius_lg}"
    },

    "figure": {
      "margin": "32px 0",
      "text-align": "center"
    },

    "figcaption": {
      "margin-top": "12px",
      "font-size": "14px",
      "color": "{colors.text_tertiary}",
      "text-align": "center"
    },

    "hr": {
      "border": "none",
      "height": "1px",
      "background": "{colors.border}",
      "margin": "36px 0"
    },

    "table": {
      "width": "100%",
      "border-collapse": "collapse",
      "margin": "28px 0",
      "border": "1px solid {colors.border}"
    },

    "th": {
      "background": "{colors.bg_cool}",
      "padding": "14px 16px",
      "text-align": "left",
      "font-weight": "600",
      "color": "{colors.accent}",
      "border": "1px solid {colors.border}",
      "font-size": "15px"
    },

    "td": {
      "padding": "12px 16px",
      "border": "1px solid {colors.border}",
      "color": "{colors.text_secondary}",
      "font-size": "15px"
    },

    "highlight_box": {
      "background": "{colors.primary_pale}",
      "border": "1px solid {colors.border_accent}",
      "border-radius": "{tokens.radius_lg}",
      "padding": "20px 24px",
      "margin": "24px 0"
    },

    "note_box": {
      "background": "{colors.bg_quote}",
      "border-left": "4px solid {colors.primary_light}",
      "border-radius": "0 {tokens.radius_md} {tokens.radius_md} 0",
      "padding": "16px 20px",
      "margin": "24px 0",
      "font-size": "15px",
      "color": "{colors.text_secondary}"
    }
  },

  "decorations": {
    "h3_prefix": {
      "symbol": "■",
      "style": {
        "color": "{colors.primary}",
        "margin-right": "8px"
      }
    }
  }
}
